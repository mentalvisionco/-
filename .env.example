# Server Configuration
PORT=5000

# Security - REQUIRED in production
# Generate a strong random key: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=your_secret_key_here

# Database path (optional, defaults to ./database.sqlite)
# DB_PATH=./database.sqlite

# Node environment
# NODE_ENV=production

# Google Drive Storage Config (OAuth2 User Authentication)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_DRIVE_FOLDER_ID=13GHoX6mNV1Oo2CKRmsiXvSjPx4UQWjjy

